# Server configuration
PORT=4242
HOST=127.0.0.1

# Where SQLite DB lives (must be writable)
DB_PATH=./data/xword.db

# Google OAuth — fill in from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Public origin of the deployed app
APP_ORIGIN=https://xword.celox.io

# OAuth redirect URI registered in Google Cloud Console
OAUTH_REDIRECT_URI=https://xword.celox.io/api/auth/callback

# 32+ random bytes for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Cookie name + lifetime (in seconds; 30 days default)
SESSION_COOKIE=xword_session
SESSION_TTL=2592000
